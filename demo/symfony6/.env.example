###> symfony/framework-bundle ###
# APP_ENV: Symfony environment for this demo.
APP_ENV=dev
# APP_SECRET: Local demo secret (never use this in production).
APP_SECRET=change_this_secret_key_to_a_random_value
# APP_DEBUG: Enable verbose debug output in development.
APP_DEBUG=1
###< symfony/framework-bundle ###

###> symfony/console ###
# In case the app is run behind a reverse proxy, set the trusted proxies
# Read https://symfony.com/doc/current/deployment/proxies.html
#TRUSTED_PROXIES=127.0.0.1,127.0.0.2
#TRUSTED_HOSTS='^localhost|example\.com$'
###< symfony/console ###

# PORT: Host port mapped to the demo HTTP service.
PORT=8001

###> symfony/routing ###
# DEFAULT_URI: Base URL used by CLI URL generation.
DEFAULT_URI=http://localhost:8001
###< symfony/routing ###

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Phone Input Bundle - Demo</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="/bundles/nowophoneinput/css/flag-icons.min.css">
    <link rel="stylesheet" href="/bundles/nowophoneinput/css/phone_input.css">
    <link rel="stylesheet" href="/css/framework-presets.css">
    <style>
        body {
            background: linear-gradient(135deg, #0ea5e9 0%, #6366f1 100%);
            min-height: 100vh;
            padding: 24px;
        }
        .demo-container {
            background: #fff;
            border-radius: 12px;
            box-shadow: 0 10px 40px rgba(0, 0, 0, 0.12);
            padding: 32px;
            max-width: 960px;
            margin: 0 auto;
        }
        .demo-header {
            text-align: center;
            margin-bottom: 28px;
        }
        .demo-header h1 {
            color: #0f172a;
            margin-bottom: 8px;
        }
        .section-heading {
            font-size: 0.875rem;
            font-weight: 600;
            letter-spacing: 0.04em;
            text-transform: uppercase;
            color: #64748b;
            margin: 24px 0 12px;
        }
        .field-card {
            border: 1px solid #e2e8f0;
            border-radius: 8px;
            padding: 16px;
            margin-bottom: 16px;
            background: #f8fafc;
        }
        .field-card h2 {
            font-size: 1rem;
            margin-bottom: 8px;
            color: #334155;
        }
        .field-card .mb-3,
        .field-card .form-group,
        .field-card .nowo-phone-input {
            width: 100%;
        }
        .field-card .form-text,
        .field-card .form-help {
            margin-top: 0.5rem;
            word-break: break-word;
        }
        .result-card {
            border-left: 4px solid #22c55e;
            background: #f0fdf4;
            padding: 12px 16px;
            margin-bottom: 12px;
            border-radius: 4px;
        }
        .result-type {
            font-size: 0.75rem;
            text-transform: uppercase;
            letter-spacing: 0.05em;
            color: #64748b;
        }
        code.result-value {
            display: block;
            margin-top: 4px;
            word-break: break-all;
        }
    </style>
</head>
<body class="demo-page {{ demo_page_class|default('demo-page--bootstrap5') }}">
    <div class="demo-container">
        <div class="demo-header">
            <h1>📞 Phone Input Bundle</h1>
            <p class="text-muted mb-0">
                Demo: <code>ValueFormat</code>, <code>PrefixDisplay</code>, <code>FlagDisplay</code>, CSS frameworks and prefix options
            </p>
        </div>

        <div class="demo-framework-switcher">
            <label for="demo-framework-select">CSS framework</label>
            <select id="demo-framework-select" class="form-select form-select-sm" aria-label="CSS framework">
                {% for frameworkId, frameworkLabel in frameworkChoices %}
                    <option value="{{ frameworkId }}"{% if frameworkId == activeFramework %} selected{% endif %}>{{ frameworkLabel }}</option>
                {% endfor %}
            </select>
            <p class="demo-framework-switcher__hint mb-0">
                Applies <code>container_classes</code>, <code>prefix_selector_classes</code> and
                <code>national_number_classes</code> to every field:
                {% for className in frameworkClasses.container_classes %}<code>{{ className }}</code>{% if not loop.last %}, {% endif %}{% endfor %}
                ·
                {% for className in frameworkClasses.prefix_selector_classes %}<code>{{ className }}</code>{% if not loop.last %}, {% endif %}{% endfor %}
                ·
                {% for className in frameworkClasses.national_number_classes %}<code>{{ className }}</code>{% if not loop.last %}, {% endif %}{% endfor %}
            </p>
        </div>

        {% if submitted and formattedResults %}
            <div class="alert alert-success" role="alert">
                <h4 class="alert-heading">Form submitted</h4>
                <p class="mb-0">Submitted values per field:</p>
            </div>
            {% for field, result in formattedResults %}
                <div class="result-card">
                    <strong>{{ field|replace({'_': ' '})|title }}</strong>
                    <div class="result-type">{{ result.type }}</div>
                    <code class="result-value">{{ result.display }}</code>
                </div>
            {% endfor %}
            <hr class="my-4">
        {% endif %}

        {{ form_start(form, {'attr': {'class': 'needs-validation', 'novalidate': true}}) }}
        <input type="hidden" name="framework" value="{{ activeFramework }}">

        {% set coreSections = {
            'phone_concatenated_with_prefix': '1. Concatenated + prefix selector',
            'phone_concatenated_without_prefix': '2. Concatenated + no prefix selector',
            'phone_separated_with_prefix': '3. Separated array + prefix selector',
            'phone_separated_without_prefix': '4. Separated array + no prefix selector',
            'phone_object_with_prefix': '5. PhoneNumber object + prefix selector',
            'phone_object_without_prefix': '6. PhoneNumber object + no prefix selector',
        } %}

        <p class="section-heading mb-0">Core formats</p>
        {% for fieldName, sectionTitle in coreSections %}
            <div class="field-card">
                <h2>{{ sectionTitle }}</h2>
                {{ form_row(form[fieldName]) }}
            </div>
        {% endfor %}

        {% set featureSections = {
            'phone_with_prefix_search': '7. Prefix selector with search',
            'phone_selector_only': '8. Prefix selector only (no search)',
            'phone_allowed_iberian': '9. Allowed countries (ES, PT only)',
            'phone_excluded_fr': '10. Excluded countries (without FR)',
            'phone_without_flag': '11. show_flag: false',
        } %}

        {% set prefixDisplaySections = {
            'phone_prefix_display_full': '12. PrefixDisplay::FULL',
            'phone_prefix_display_prefix_only': '13. PrefixDisplay::PREFIX_ONLY',
            'phone_prefix_display_flag_and_prefix': '14. PrefixDisplay::FLAG_AND_PREFIX',
            'phone_prefix_display_iso_and_prefix': '15. PrefixDisplay::ISO_AND_PREFIX',
            'phone_prefix_display_flag_only': '16. PrefixDisplay::FLAG_ONLY',
        } %}

        {% set flagDisplaySections = {
            'phone_flag_display_emoji': '17. FlagDisplay::EMOJI',
            'phone_flag_display_css_icon': '18. FlagDisplay::CSS_ICON',
            'phone_flag_display_ux_icon': '19. FlagDisplay::UX_ICON',
            'phone_flag_display_none': '20. FlagDisplay::NONE',
        } %}

        <p class="section-heading mb-0">Prefix options</p>
        {% for fieldName, sectionTitle in featureSections %}
            <div class="field-card">
                <h2>{{ sectionTitle }}</h2>
                {{ form_row(form[fieldName]) }}
            </div>
        {% endfor %}

        <p class="section-heading mb-0">Prefix display modes</p>
        {% for fieldName, sectionTitle in prefixDisplaySections %}
            <div class="field-card">
                <h2>{{ sectionTitle }}</h2>
                {{ form_row(form[fieldName]) }}
            </div>
        {% endfor %}

        <p class="section-heading mb-0">Flag display modes</p>
        {% for fieldName, sectionTitle in flagDisplaySections %}
            <div class="field-card">
                <h2>{{ sectionTitle }}</h2>
                {{ form_row(form[fieldName]) }}
            </div>
        {% endfor %}

        <div class="d-grid mt-3">
            {{ form_widget(form.submit) }}
        </div>
        {{ form_end(form, {'render_rest': false}) }}

        <div class="mt-4 text-center">
            <small class="text-muted">
                Powered by <a href="https://github.com/nowo-tech/PhoneInputBundle" target="_blank">Phone Input Bundle</a>
            </small>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        (function () {
            const select = document.getElementById('demo-framework-select');
            if (!select) {
                return;
            }

            select.addEventListener('change', function () {
                const url = new URL(window.location.href);
                url.searchParams.set('framework', select.value);
                window.location.href = url.toString();
            });
        })();
    </script>
</body>
</html>
